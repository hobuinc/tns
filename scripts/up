#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd)
# Run Terraform from the repo-managed Pixi environment instead of a pre-activated shell.
source "$SCRIPT_DIR/pixi_env"

CMD=(tns_pixi_exec terraform apply)

VAR_PATH="${1:-}"
if [[ -n "${VAR_PATH}" ]]; then
    VAR_PATH=$(realpath "$VAR_PATH")
    echo "VAR_PATH adjusted to ${VAR_PATH}"
    CMD+=(--var-file "$VAR_PATH")
fi
shift $(( $# > 0 ? 1 : 0 ))
if (( $# > 0 )); then
    CMD+=("$@")
fi
printf '%s\n' "${CMD[*]}"

cd "$SCRIPT_DIR/../terraform"
"${CMD[@]}"
