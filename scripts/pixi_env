#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd)
REPO_ROOT=$(cd -- "$SCRIPT_DIR/.." &> /dev/null && pwd)
export TNS_PIXI_MANIFEST="$REPO_ROOT/pixi.toml"

tns_pixi_exec() {
    pixi run --manifest-path "$TNS_PIXI_MANIFEST" --executable "$@"
}
